    {
      "name": "2a181d47",
      "displayName": "Customer Purchase Summary Metrics Dataset",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT CUSTOMER_ID) AS TOTAL_CUSTOMERS,\n",
        "  SUM(TOTAL_AMOUNT) AS TOTAL_REVENUE,\n",
        "  AVG(TOTAL_AMOUNT) AS AVG_TRANSACTION_AMT,\n",
        "  MIN(TOTAL_AMOUNT) AS MIN_TRANSACTION_AMT,\n",
        "  MAX(TOTAL_AMOUNT) AS MAX_TRANSACTION_AMT\n",
        "FROM\n",
        "  retail_transactions;"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "23d58951",
      "displayName": "Customer Demographics Grouped by Age Gender and Income",
      "queryLines": [
        "SELECT\n",
        "  CASE\n",
        "    WHEN customer.AGE BETWEEN 18 AND 24 THEN '18 - 24'\n",
        "    WHEN AGE BETWEEN 25 AND 34 THEN '25 - 34'\n",
        "    WHEN AGE BETWEEN 35 AND 44 THEN '35 - 44'\n",
        "    WHEN AGE BETWEEN 45 AND 54 THEN '45 - 54'\n",
        "    WHEN AGE BETWEEN 55 AND 64 THEN '55 - 64'\n",
        "    WHEN AGE > 65 THEN '65+'\n",
        "  END AS AGE_GROUP,\n",
        "  customer.GENDER AS GENDER,\n",
        "  customer.INCOME AS INCOME_LEVEL,\n",
        "  COUNT(DISTINCT customer.CUSTOMER_ID) AS CUSTOMER_COUNT\n",
        "FROM\n",
        "  retail_customers customer\n",
        "    JOIN retail_transactions transactions\n",
        "      ON customer.CUSTOMER_ID = transactions.CUSTOMER_ID\n",
        "WHERE customer.GENDER IS NOT NULL\n",
        "  AND customer.AGE IS NOT NULL\n",
        "  AND customer.INCOME IS NOT NULL\n",
        "GROUP BY\n",
        "  AGE_GROUP,\n",
        "  GENDER,\n",
        "  INCOME_LEVEL\n",
        "HAVING AGE_GROUP IS NOT NULL;"
      ]
    },
    {
      "name": "2204f2c1",
      "displayName": "Top Performing States by Revenue",
      "queryLines": [
        "SELECT\n",
        "  customer.State AS STATE,\n",
        "  ROUND(SUM(transactions.TOTAL_AMOUNT), 2) AS TOTAL_REVENUE,\n",
        "  COUNT(DISTINCT customer.CUSTOMER_ID) AS CUSTOMER_COUNT,\n",
        "  COUNT(transactions.TRANSACTION_ID) AS TRANSACTION_COUNT,\n",
        "  ROUND(AVG(transactions.TOTAL_AMOUNT), 2) AS AVG_TRANSACTION_AMOUNT\n",
        "FROM\n",
        "  retail_customers customer\n",
        "    JOIN retail_transactions transactions\n",
        "      ON customer.CUSTOMER_ID = transactions.CUSTOMER_ID\n",
        "WHERE\n",
        "  customer.State IS NOT NULL\n",
        "GROUP BY\n",
        "  customer.State\n",
        "ORDER BY\n",
        "  TOTAL_REVENUE DESC"
      ]
    },
    {
      "name": "a9e31272",
      "displayName": "Brand Revenue and Rating Insights Summary",
      "queryLines": [
        "SELECT\n",
        "  PRODUCT_BRAND,\n",
        "  ROUND(SUM(TOTAL_AMOUNT), 2) AS TOTAL_REVENUE,\n",
        "  ROUND(AVG(RATINGS), 2) AS AVG_RATING,\n",
        "  RANK() OVER (ORDER BY SUM(TOTAL_AMOUNT) DESC) AS REVENUE_RANK\n",
        "FROM\n",
        "  retail_transactions\n",
        "WHERE\n",
        "  PRODUCT_BRAND IS NOT NULL\n",
        "GROUP BY\n",
        "  PRODUCT_BRAND\n",
        "ORDER BY\n",
        "  REVENUE_RANK;"
      ]
    },
    {
      "name": "fb56d904",
      "displayName": "Monthly Revenue Insights and Customer Trends",
      "queryLines": [
        "WITH MONTHLY_REVENUE_CUSTOMERS AS (\n",
        "  SELECT\n",
        "    EXTRACT(MONTH FROM TRANSACTION_DATE) AS TRANSACTION_MONTH,\n",
        "    TO_CHAR(TRANSACTION_DATE, 'MMMM') AS TRANSACTION_MONTHNAME,\n",
        "    ROUND(SUM(TOTAL_AMOUNT), 2) AS TOTAL_REVENUE,\n",
        "    COUNT(DISTINCT CUSTOMER_ID) AS CUSTOMER_COUNT\n",
        "  FROM\n",
        "    retail_transactions\n",
        "  WHERE\n",
        "    TRANSACTION_DATE IS NOT NULL\n",
        "  GROUP BY\n",
        "    TRANSACTION_MONTH,\n",
        "    TRANSACTION_MONTHNAME\n",
        "  ORDER BY\n",
        "    TRANSACTION_MONTH\n",
        ")\n",
        "SELECT\n",
        "  TRANSACTION_MONTH,\n",
        "  TRANSACTION_MONTHNAME,\n",
        "  TOTAL_REVENUE,\n",
        "  CUSTOMER_COUNT,\n",
        "  ROUND(\n",
        "    TOTAL_REVENUE - LAG(TOTAL_REVENUE) OVER (ORDER BY TRANSACTION_MONTH),\n",
        "    2\n",
        "  ) AS CHANGE_IN_REVENUE,\n",
        "  CUSTOMER_COUNT - LAG(CUSTOMER_COUNT) OVER (ORDER BY TRANSACTION_MONTH) AS CHANGE_IN_CUSTOMER_COUNT\n",
        "FROM\n",
        "  MONTHLY_REVENUE_CUSTOMERS\n",
        "ORDER BY\n",
        "  TRANSACTION_MONTH;"
      ]
    },
    {
      "name": "b1980c2b",
      "displayName": "Segment Performance Insights",
      "queryLines": [
        "WITH SEGMENT_REVENUE AS (\n",
        "  SELECT\n",
        "    CUSTOMER_SEGMENT,\n",
        "    ROUND(SUM(TOTAL_AMOUNT), 2) AS TOTAL_REVENUE,\n",
        "    ROUND(AVG(RATINGS), 2) AS AVG_RATING,\n",
        "    COUNT(DISTINCT customer.CUSTOMER_ID) AS CUSTOMER_COUNT\n",
        "  FROM\n",
        "    retail_customers customer\n",
        "      JOIN retail_transactions transactions\n",
        "        ON customer.CUSTOMER_ID = transactions.CUSTOMER_ID\n",
        "  WHERE\n",
        "    CUSTOMER_SEGMENT IS NOT NULL\n",
        "  GROUP BY\n",
        "    CUSTOMER_SEGMENT\n",
        ")\n",
        "SELECT\n",
        "  CUSTOMER_SEGMENT,\n",
        "  TOTAL_REVENUE,\n",
        "  AVG_RATING,\n",
        "  ROUND(TOTAL_REVENUE / CUSTOMER_COUNT, 2) AS REVENUE_PER_CUSTOMER,\n",
        "  ROUND(100 * TOTAL_REVENUE / SUM(TOTAL_REVENUE) OVER (), 2) AS REVENUE_SHARE_PCT,\n",
        "  RANK() OVER (ORDER BY TOTAL_REVENUE DESC) AS REVENUE_RANK\n",
        "FROM\n",
        "  SEGMENT_REVENUE\n",
        "ORDER BY\n",
        "  REVENUE_RANK;"
      ]
    },
    {
      "name": "ratings_distribution",
      "displayName": "Ratings Distribution by Brand",
      "queryLines": [
        "SELECT\n",
        "  Product_Brand,\n",
        "  Ratings,\n",
        "  COUNT(*) AS Rating_Count\n",
        "FROM\n",
        "  retail_transactions\n",
        "WHERE\n",
        "  Product_Brand IS NOT NULL\n",
        "  AND Ratings IS NOT NULL\n",
        "GROUP BY\n",
        "  Product_Brand,\n",
        "  Ratings\n",
        "ORDER BY\n",
        "  Product_Brand,\n",
        "  Ratings"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "6fa060e7",
      "displayName": "Monthly Retail Revenue and Growth by Product Category",
      "queryLines": [
        "WITH monthly_revenue AS (\n",
        "  SELECT\n",
        "    COALESCE(Product_Category, 'Unknown') AS Product_Category,\n",
        "    SUM(\n",
        "      CASE\n",
        "        WHEN EXTRACT(MONTH FROM Transaction_Date) = 7 THEN Total_Amount\n",
        "        ELSE 0\n",
        "      END\n",
        "    ) AS Total_Revenue_July,\n",
        "    SUM(\n",
        "      CASE\n",
        "        WHEN EXTRACT(MONTH FROM Transaction_Date) = 8 THEN Total_Amount\n",
        "        ELSE 0\n",
        "      END\n",
        "    ) AS Total_Revenue_August\n",
        "  FROM\n",
        "    workspace.default.retail_transactions\n",
        "  GROUP BY\n",
        "    Product_Category\n",
        ")\n",
        "SELECT\n",
        "  Product_Category,\n",
        "  Total_Revenue_July,\n",
        "  Total_Revenue_August,\n",
        "  Total_Revenue_August - Total_Revenue_July AS Revenue_Difference,\n",
        "  SUM(Total_Revenue_August - Total_Revenue_July) OVER () AS Total_Revenue_Difference\n",
        "FROM\n",
        "  monthly_revenue\n",
        "ORDER BY\n",
        "  Revenue_Difference DESC"
      ]
    }
  ],
